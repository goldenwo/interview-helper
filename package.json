{
  "name": "interview-helper",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host\" \"tsx server/index.ts\"",
    "dev:frontend": "vite --host",
    "dev:server": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "express": "^5.1.0",
    "openai": "^4.85.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1",
    "tsx": "^4.19.0",
    "concurrently": "^9.1.0"
  }
}
